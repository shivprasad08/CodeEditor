PORT=4000
CLIENT_ORIGIN=http://localhost:5173
MONGO_URI=mongodb://localhost:27017/codeeditor
MONGO_DB_NAME=codeeditor
WORKER_COUNT=3
CODE_TIMEOUT_MS=60000
# auto | docker | local
CODE_RUNNER_MODE=auto
# true uses local runner first for languages that support it (e.g. javascript)
CODE_RUNNER_AUTO_PREFER_LOCAL=true
